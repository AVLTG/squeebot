# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord client/application ID (found on the "General Information" tab of your Discord app)
DISCORD_CLIENT_ID=your_discord_client_id_here

# Which LLM provider to use. Options: "groq" (default, fast + generous free tier)
# or "gemini" (fallback, Flash Lite — free tier dropped to ~20 RPD).
LLM_PROVIDER=groq

# Groq API key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key from https://aistudio.google.com/apikey (fallback provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: comma-separated list of channel IDs where Squee is allowed to respond.
# Leave blank to allow all channels.
ALLOWED_CHANNEL_IDS=

# Optional: set to "debug" for verbose logging, "info" for normal
LOG_LEVEL=info
