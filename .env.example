# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord client/application ID (found on the "General Information" tab of your Discord app)
DISCORD_CLIENT_ID=your_discord_client_id_here

# Which LLM provider to use. Options:
#   "cascade" (default) — try Groq → Gemini → Modal, advancing on 429 only
#   "groq"              — Groq's llama-3.3-70b (fast, generous free tier)
#   "gemini"            — Gemini Flash Lite (free tier ~20 RPD)
#   "modal"             — our fine-tuned Llama 3.1 8B AWQ on Modal
LLM_PROVIDER=cascade

# Groq API key from https://console.groq.com/keys
# Required for "groq" provider AND for memory-updates when using "modal" provider.
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key from https://aistudio.google.com/apikey (fallback provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Modal vLLM endpoint URL (required when LLM_PROVIDER=modal).
# Looks like: https://<workspace>--squee-vllm-serve.modal.run
MODAL_VLLM_URL=

# Bearer token for the Modal vLLM endpoint (required when LLM_PROVIDER=modal).
# Same value as the VLLM_API_KEY in the `squee-vllm-key` Modal secret.
SQUEE_VLLM_KEY=

# Optional: comma-separated list of channel IDs where Squee is allowed to respond.
# Leave blank to allow all channels.
ALLOWED_CHANNEL_IDS=

# Optional: set to "debug" for verbose logging, "info" for normal
LOG_LEVEL=info
